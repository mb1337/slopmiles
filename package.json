{
  "name": "slopmiles",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "turbo run build",
    "convex:codegen": "convex codegen",
    "convex:dev": "convex dev",
    "dev": "turbo run dev --parallel",
    "dev:mobile": "pnpm --filter @slopmiles/mobile dev",
    "dev:web": "pnpm --filter @slopmiles/web dev",
    "test": "vitest run",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/react": "^19.2.14",
    "convex": "^1.32.0",
    "convex-test": "^0.0.41",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/workflow": "^0.3.6",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "ai": "^5.0.29",
    "jose": "^6.1.3",
    "zod": "^4.3.6"
  }
}
