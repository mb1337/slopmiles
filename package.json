{
  "name": "slopmiles",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "turbo run build",
    "convex:codegen": "convex codegen",
    "convex:dev": "convex dev",
    "dev": "turbo run dev --parallel",
    "dev:mobile": "pnpm --filter @slopmiles/mobile dev",
    "dev:web": "pnpm --filter @slopmiles/web dev",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "convex": "^1.32.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "jose": "^6.1.3"
  }
}
